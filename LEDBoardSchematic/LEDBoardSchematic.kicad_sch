	(text "Note: LED Panel rows will typically consist of multiple panels. In this instance for\neach row you should daisy chain the LED panels by connecting the last panel's DOUT to\nthe next panel's DIN in the according row\n"
		(exclude_from_sim no)
		(at 164.846 137.922 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "389827aa-e8b3-40be-8bd0-404b486d519d")
	)
	(text "IMPORTANT: Note that +5V AND +5V Power Supply are two DIFFERENT 5V lines. \nThe Power Supply line is designed to support the led panels and both lines should NOT be connected under any conditions"
		(exclude_from_sim no)
		(at 165.1 56.642 0)
		(effects
			(font
				(size 1.27 1.27)
			)
